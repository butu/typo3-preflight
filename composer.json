{
  "name": "webprofil/typo3-preflight",
  "description": "Deterministic pre-flight integration checks for TYPO3 projects running in DDEV.",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.2",
    "symfony/console": "^6.4 || ^7.0",
    "symfony/process": "^6.4 || ^7.0",
    "symfony/yaml": "^6.4 || ^7.0",
    "symfony/filesystem": "^6.4 || ^7.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "WEBprofil\\Typo3Preflight\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WEBprofil\\Typo3Preflight\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/wp-typo3-preflight"
  ],
  "config": {
    "sort-packages": true
  }
}
